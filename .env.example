# Anthropic API key for live Claude calls from the evaluator pipeline.
# CI uses MockJsonOutputProvider and never reads this.
ANTHROPIC_API_KEY=

# Optional model override for the evaluator. Defaults to claude-opus-4-7.
# ANTHROPIC_MODEL=claude-opus-4-7

# Override the runtime data directory. Defaults to ~/.networkpipeline.
# NETWORKPIPELINE_HOME=

# Override the criteria file path. Defaults to $NETWORKPIPELINE_HOME/criteria.yaml.
# NETWORKPIPELINE_CRITERIA_PATH=
